.container {
  padding: 24rpx;
  background: #f7f7f7;
  min-height: 100vh;
  box-sizing: border-box;
}

.order-num {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #333;
}

.item {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.pic {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
}

.item-right {
  flex: 1;
  margin-left: 18rpx;
}

.name {
  font-size: 28rpx;
  color: #111;
}

.sku {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.status {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.actions {
  margin-top: 14rpx;
}

.form {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 24rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  margin-bottom: 16rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.btn-row {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.btn {
  flex: 1;
  margin: 0 10rpx;
}

.gray {
  background: #f0f0f0;
  color: #666;
}

.primary {
  background: #eb2444;
  color: #ffffff;
}
