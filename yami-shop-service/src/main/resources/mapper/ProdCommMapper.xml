<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yami.shop.dao.ProdCommMapper">

    <resultMap id="prodCommDtoMap" type="com.yami.shop.bean.app.dto.ProdCommDto">
        <id column="comm_id" property="commId"/>
        <result column="prod_id" property="prodId"/>
        <result column="score" property="score"/>
        <result column="content" property="content"/>
        <result column="pics" property="pics"/>
        <result column="is_anonymous" property="isAnonymous"/>
        <result column="rec_time" property="recTime"/>
        <result column="nick_name" property="nickName"/>
        <result column="pic" property="pic"/>
    </resultMap>

    <select id="getProdCommList" resultMap="prodCommDtoMap">
        SELECT pc.comm_id, pc.prod_id, pc.score, pc.content, pc.pics, pc.is_anonymous, pc.rec_time,
               u.nick_name, u.pic
        FROM prod_comm pc
        LEFT JOIN tz_user u ON pc.user_id = u.user_id
        WHERE pc.prod_id = #{prodId} AND pc.status = 1
        ORDER BY pc.rec_time DESC
        LIMIT #{page.begin}, #{page.size}
    </select>

    <select id="countProdComm" resultType="java.lang.Long">
        SELECT COUNT(*) FROM prod_comm WHERE prod_id = #{prodId} AND status = 1
    </select>

</mapper>
